#include <stdarg.h>
#include <unistd.h>

static void ft_putstr(char *str, int *count)
{
    if (!str)
        str = "(null)";
    while (*str)
    {
        write(1, str++, 1);
        (*count)++;
    }
}

static void ft_putnbr(int nbr, int *count)
{
    char c;

    if (nbr == -2147483648)
    {
        ft_putstr("-2147483648", count);
        return;
    }
    if (nbr < 0)
    {
        write(1, "-", 1);
        nbr *= -1;
        (*count)++;
    }
    if (nbr > 9)
        ft_putnbr(nbr / 10, count);
    c = (nbr % 10) + '0';
    write(1, &c, 1);
    (*count)++;
}

static void ft_puthex(unsigned int nbr, int *count)
{
    char *hex = "0123456789abcdef";
    if (nbr > 15)
        ft_puthex(nbr / 16, count);
    write(1, &hex[nbr % 16], 1);
    (*count)++;
}


int ft_printf(const char *format, ...)
{
    va_list list;
    int count;

    count = 0;
    va_start(list, format);
    while (*format)
    {
        if (*format == '%' && *(format + 1))
        {
            format++;
            if (*format == 's')
                ft_putstr(va_arg(list, char *), &count);
            else if (*format == 'd')
                ft_putnbr(va_arg(list, int), &count);
            else if (*format == 'x')
                ft_puthex(va_arg(list, unsigned int), &count);
            else
            {
                write(1, format, 1);
                count++;
            }
        }
        else
        {
            write(1, format, 1);
            count++;
        }
        format++;
    }
    va_end(list);
    return (count);
}

#include <stdio.h>

int main(void)
{
    ft_printf("hi %d%d %s %x\n", 10, 10, "hi", 10);
    printf("hi %d%d %s %x\n", 10, 10, "hi", 10);
}
